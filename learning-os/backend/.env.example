# Database
MONGODB_URI=mongodb://localhost:27017/learning-os

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production (minimum 32 characters)
JWT_SECRET=your-super-secret-key-change-this-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_ISSUER=learning-os

# Encryption key for user-level secrets (must be exactly 32 characters)
# Example generator:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Server
PORT=5001
NODE_ENV=development

# CORS (optional - defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Optional code execution provider config (Interview /run and /submit)
# Example public endpoint:
# PISTON_BASE_URL=https://emkc.org/api/v2/piston
PISTON_BASE_URL=
# Comma-separated backup endpoints
PISTON_FALLBACK_BASE_URLS=
# Optional provider auth
PISTON_API_KEY=
# Header used for key (default Authorization)
PISTON_API_KEY_HEADER=Authorization
# Prefix for key value; set empty to send raw key (default Bearer)
PISTON_API_KEY_PREFIX=Bearer
# Request timeout in ms (default 10000)
PISTON_TIMEOUT_MS=10000
