# Script Writer Service Environment Variables

# Server
PORT=5003
NODE_ENV=development

# MongoDB (falls back to MONGODB_URI if SCRIPT_WRITER_MONGODB_URI is empty)
MONGODB_URI=mongodb://localhost:27017/learning-os
SCRIPT_WRITER_MONGODB_URI=

# Ollama LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional cloud LLM providers
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# JWT (must match main backend if shared auth is used)
JWT_SECRET=your-jwt-secret-here
SCRIPT_WRITER_JWT_SECRET=

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
