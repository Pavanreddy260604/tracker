{
    "name": "script-writer-service",
    "version": "1.0.0",
    "description": "AI-powered Hollywood-standard script writer microservice",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "verify:assistant-contracts": "tsx verify_assisted_edit_contracts.ts",
        "verify:assistant-rag": "tsx verify_assistant_rag_upgrade.ts",
        "verify:exact-reconstruction": "npm run build && node --experimental-strip-types verify_exact_screenplay_reconstruction.ts",
        "embed:download-model": "python scripts/download_transformers_model.py",
        "fix:scene-sequences": "tsx src/scripts/fixSceneSequenceConflicts.ts --apply",
        "fix:scene-sequences:dry": "tsx src/scripts/fixSceneSequenceConflicts.ts",
        "audit:ge:scheduled": "tsx src/scripts/runScheduledGeAudits.ts"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@llamaindex/chroma": "^0.0.36",
        "@llamaindex/core": "^0.6.22",
        "@llamaindex/ollama": "^0.1.23",
        "@llamaindex/readers": "^3.1.21",
        "@types/ioredis": "^4.28.10",
        "axios": "^1.6.0",
        "chromadb": "^3.2.2",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "groq-sdk": "^0.37.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "llamaindex": "^0.12.1",
        "mammoth": "^1.11.0",
        "mongoose": "^8.0.0",
        "morgan": "^1.10.1",
        "multer": "^1.4.5-lts.1",
        "pdf-parse": "^1.1.1",
        "pdfjs-dist": "^5.5.207",
        "pdfkit": "^0.17.2"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.15",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^1.4.10",
        "@types/node": "^20.10.0",
        "@types/pdfkit": "^0.17.5",
        "tsx": "^4.6.0",
        "typescript": "^5.3.0"
    }
}
